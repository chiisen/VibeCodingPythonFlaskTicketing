# ==============================================================================
# 環境變數設定範本
# 請複製此檔案為 .env 並填入正確的值
# ==============================================================================

# Flask 設定
FLASK_APP=app.py
FLASK_ENV=development
# 支援格式: 1/0, true/false, yes/no, on/off (不分大小寫)
FLASK_DEBUG=1

# 安全設定 - 請使用隨機生成的密鑰
# 命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_secret_key_here

# 資料庫設定 (未來整合時使用)
DATABASE_URL=sqlite:///app.db

# 郵件服務設定 (未來使用)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
